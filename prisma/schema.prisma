generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

//////////////////////////
// 🔐 AUTH MODELS
//////////////////////////

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // role: PARENT | ADMIN | REVIEWER
  role     String  @default("PARENT")
  isActive Boolean @default(true)

  phone   String?
  address String?

  accounts Account[]
  sessions Session[]

  applications      Application[] // as parent
  reviewAssignments ReviewAssignment[] // as reviewer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//////////////////////////
// 📝 APPLICATION
//////////////////////////

// status: DRAFT | SUBMITTED | UNDER_REVIEW | ACCEPTED | REJECTED

model Application {
  id String @id @default(cuid())

  // Student info
  studentName    String
  dob            DateTime
  gender         String // "MALE" | "FEMALE" | "OTHER"
  applyingClass  String
  previousSchool String?

  // Parent
  parentId String
  parent   User   @relation(fields: [parentId], references: [id])

  // Status
  status String @default("DRAFT") // "DRAFT" | "SUBMITTED" | "UNDER_REVIEW" | "ACCEPTED" | "REJECTED"

  // Relations
  reviewAssignment ReviewAssignment?
  auditLogs        AuditLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  @@index([parentId])
  @@index([status])
}

//////////////////////////
// 🔍 REVIEW ASSIGNMENT
//////////////////////////

// recommendation: ACCEPT | REJECT | PENDING
model ReviewAssignment {
  id String @id @default(cuid())

  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   User   @relation(fields: [reviewerId], references: [id])

  remarks        String?
  recommendation String  @default("PENDING") // "ACCEPT" | "REJECT" | "PENDING"

  assignedAt DateTime  @default(now())
  reviewedAt DateTime?
}

//////////////////////////
// 📋 AUDIT LOG
//////////////////////////

model AuditLog {
  id String @id @default(cuid())

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  actorId    String // userId who performed the action
  actorRole  String // "ADMIN" | "REVIEWER" | "PARENT"
  action     String // e.g. "STATUS_CHANGED", "REVIEWER_ASSIGNED", "SUBMITTED"
  fromStatus String?
  toStatus   String?
  note       String?

  createdAt DateTime @default(now())

  @@index([applicationId])
}
